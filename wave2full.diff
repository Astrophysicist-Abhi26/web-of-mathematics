-  text-transform:uppercase;display:flex;align-items:center;gap:7px;margin-bottom:5px;color:var(--ink-soft);}
-.p-eyebrow .dot{width:9px;height:9px;border-radius:50%;}
-#panel h2{font-family:'Spectral',serif;font-size:23px;font-weight:600;margin:2px 0 10px;line-height:1.2;}
-#panel p.def{font-size:14.5px;line-height:1.55;margin:0 0 14px;color:#2c2820;}
-.section-label{font-family:'IBM Plex Mono',monospace;font-size:10px;text-transform:uppercase;
-  color:var(--ink-soft);letter-spacing:0.6px;margin:14px 0 6px;}
-ul.theorems{margin:0;padding-left:18px;font-size:13.5px;line-height:1.6;color:#33302a;}
-.book{font-size:13px;color:#4a4438;font-style:italic;}
-.chips{display:flex;flex-wrap:wrap;gap:6px;}
-.chip{background:rgba(0,0,0,0.05);border:1px solid rgba(0,0,0,0.14);border-radius:999px;
-  padding:5px 11px;font-size:12.5px;cursor:pointer;font-family:'Inter',sans-serif;color:var(--ink);}
-.chip:active,.chip:hover{background:rgba(0,0,0,0.12);}
-.chip.stub{cursor:default;opacity:0.75;border-style:dashed;}
-.via-box{background:#f1e2b8;border-left:3px solid var(--gold);border-radius:0 8px 8px 0;
-  padding:10px 13px;font-size:13.5px;line-height:1.5;margin:6px 0 14px;color:#3a2f14;}
-.via-box b{font-family:'IBM Plex Mono',monospace;font-size:10.5px;text-transform:uppercase;
-  display:block;margin-bottom:4px;color:#7a5a10;letter-spacing:0.5px;}
-.edge-title{display:flex;align-items:center;gap:8px;font-family:'Spectral',serif;
-  font-size:19px;font-weight:600;margin:2px 0 10px;flex-wrap:wrap;}
-.edge-title .arrow{color:var(--gold);font-size:16px;}
-.closebtn{position:absolute;top:12px;right:14px;width:30px;height:30px;border-radius:50%;
-  border:none;background:rgba(0,0,0,0.06);color:var(--ink);font-size:15px;cursor:pointer;z-index:2;}
-
-/* intro overlay */
-#intro{position:absolute;left:50%;top:46%;transform:translate(-50%,-50%);
-  text-align:center;pointer-events:none;z-index:4;transition:opacity .5s;max-width:82%;}
-#intro.gone{opacity:0;}
-#intro .big{font-family:'Spectral',serif;font-size:15px;color:var(--text-dim);font-style:italic;}
-
-/* ---------- L3 topics (Part 3) ---------- */
-#layer-topics{opacity:0;pointer-events:none;}
-.topic-spoke{stroke-opacity:0.28;stroke-width:0.8;}
-.topic-dot{}
-/* L2 voice — small sans regular, muted: legible up close, recessive by design */
-.topic-label{font-family:'Inter',system-ui,sans-serif;font-size:10.5px;font-weight:400;
-  fill:#a9b2c4;opacity:0.72;
-  paint-order:stroke;stroke:#0e1117;stroke-width:2px;stroke-linejoin:round;}
-.label-hidden{display:none;}
-.topic-hit{fill:transparent;cursor:pointer;}
-.topic-g:active .topic-dot{stroke-width:2.4;}
-
-/* Schuller companion line */
-.schuller{font-size:12.5px;font-family:'IBM Plex Mono',monospace;color:#3a4356;
-  background:#e7ecf5;border-left:3px solid #5b9ce0;border-radius:0 8px 8px 0;
-  padding:8px 11px;margin:2px 0 10px;}
-
-/* atom (interactive) button */
-.atom-btn{display:block;text-decoration:none;font-size:13px;font-weight:600;
-  color:#1c2a16;background:linear-gradient(180deg,#dff0d0,#cfe6bd);
-  border:1px solid #a9c98f;border-radius:10px;padding:10px 12px;margin:10px 0 4px;}
-.atom-btn:active{filter:brightness(0.95);}
-
-/* ============================================================
-   PART 4 — VISUAL OVERHAUL: deep-space, glow, motion
-   ============================================================ */
-body{background:radial-gradient(1200px 800px at 30% 10%, #141a26 0%, #0b0e15 55%, #07090e 100%);}
-#svg{background:transparent;}
-
-/* animated title shimmer */
-header h1{background:linear-gradient(90deg,#e9e6dc 0%,#ffd98a 45%,#e9e6dc 60%);
-  background-size:220% 100%;-webkit-background-clip:text;background-clip:text;
-  -webkit-text-fill-color:transparent;animation:shimmer 7s linear infinite;}
-header h1 em{-webkit-text-fill-color:var(--gold);}
-@keyframes shimmer{to{background-position:-220% 0;}}
-#search:focus{box-shadow:0 0 0 3px rgba(217,164,65,0.18),0 0 18px rgba(217,164,65,0.25);}
-
-/* starfield */
-.star{fill:#fff;opacity:0.1;animation:twinkle 3s ease-in-out infinite;}
-@keyframes twinkle{0%,100%{opacity:0.06}50%{opacity:0.55}}
-
-/* domains: nebula + slow-spinning dashed ring + glowing core */
-.domain-nebula{pointer-events:none;transition:opacity .4s;}
-.domain-ring{fill:none;stroke-width:1.2;stroke-dasharray:3 12;opacity:0.55;
-  transform-box:fill-box;transform-origin:center;animation:spin 80s linear infinite;
-  pointer-events:none;transition:opacity .4s;}
-@keyframes spin{to{transform:rotate(360deg)}}
-.domain-halo{stroke-dasharray:none;}
-.domain-core{transition:opacity .4s;}
-.domain-g:hover .domain-ring{opacity:0.95;animation-duration:24s;}
-
-/* fields: springy entry + breathing pulse ring + glow orb */
-.enter{transform-box:fill-box;transform-origin:center;
-  animation:enter .8s cubic-bezier(.18,.9,.28,1.35) both;}
-@keyframes enter{from{opacity:0;transform:scale(0.2)}to{opacity:1;transform:scale(1)}}
-.field-pulse{fill:none;opacity:0;transform-box:fill-box;transform-origin:center;
-  animation:pulse 3s ease-out infinite;}
-.field-g:nth-child(3n) .field-pulse{animation-delay:.9s;}
-.field-g:nth-child(3n+1) .field-pulse{animation-delay:1.8s;}
-@keyframes pulse{0%{transform:scale(.7);opacity:.85;stroke-width:2}
-  70%{transform:scale(2.1);opacity:0;stroke-width:.5}100%{opacity:0}}
-.field-g{cursor:pointer;}
-.field-g:hover .field-orb,.field-g:active .field-orb{r:12;}
-.field-orb{transition:r .18s ease;}
-.field-label{paint-order:stroke;stroke:#0b0e15;stroke-width:3px;stroke-linejoin:round;}
-
-/* bridges: golden energy flowing along the arc */
-.edge-sig{stroke-dasharray:7 12;animation:flow 1.1s linear infinite;filter:url(#glowE);}
-@keyframes flow{to{stroke-dashoffset:-19}}
-.edge-pre{stroke-opacity:0.3;}
-.via-label{paint-order:stroke;stroke:#0b0e15;stroke-width:3px;stroke-linejoin:round;}
-
-/* topic dots stay flat — glow is reserved for navigable levels (211 dots
-   with filters was the pan-stutter culprit) */
-.topic-g{cursor:pointer;}
-
-/* glass panel replaces paper */
-#panel{background:rgba(15,18,27,0.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
-  color:var(--text);border-top:1px solid rgba(217,164,65,0.4);
-  box-shadow:0 -12px 50px rgba(0,0,0,0.6),0 0 40px rgba(217,164,65,0.06);}
-.panel-handle{background:rgba(255,255,255,0.22);}
-#panel h2{color:#f4e9cf;text-shadow:0 0 22px rgba(217,164,65,0.35);}
-#panel p.def{color:#cfd3dc;}
-.p-eyebrow{color:var(--text-dim);}
-.section-label{color:#8f95a3;border-color:rgba(255,255,255,0.12);}
-.book{color:#b9ac89;}
-.chips .chip{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.14);color:#dfe3ea;}
-.chips .chip:hover,.chips .chip:active{background:rgba(217,164,65,0.18);border-color:rgba(217,164,65,0.5);}
-.chip.stub{opacity:0.55;}
-.via-box{background:rgba(217,164,65,0.1);border-left:3px solid var(--gold);color:#e8dcbd;}
-.via-box b{color:var(--gold);}
-.schuller{background:rgba(91,156,224,0.1);border-left:3px solid #5b9ce0;color:#bcd3ee;}
-.atom-btn{background:linear-gradient(180deg,rgba(87,171,121,0.25),rgba(87,171,121,0.12));
-  border:1px solid rgba(87,171,121,0.55);color:#c9ecd4;text-shadow:0 0 12px rgba(87,171,121,0.4);
-  box-shadow:0 0 18px rgba(87,171,121,0.15);}
-.zbtn{backdrop-filter:blur(8px);background:rgba(15,18,27,0.7);}
-.zbtn:hover{border-color:var(--gold);color:var(--gold);box-shadow:0 0 14px rgba(217,164,65,0.25);}
-#closepanel{background:rgba(255,255,255,0.08);color:var(--text);}
-
-/* ---------- Part 5: bridge story card, browse index, toolbar button ---------- */
-.tbtn{background:linear-gradient(180deg,rgba(217,164,65,0.22),rgba(217,164,65,0.1));
-  border:1px solid rgba(217,164,65,0.5);color:#f0e2bd;font-family:'Inter',sans-serif;
-  font-size:12.5px;font-weight:600;padding:9px 14px;border-radius:999px;cursor:pointer;
-  white-space:nowrap;text-shadow:0 0 12px rgba(217,164,65,0.35);transition:all .18s;}
-.tbtn:hover{background:rgba(217,164,65,0.32);box-shadow:0 0 18px rgba(217,164,65,0.3);transform:translateY(-1px);}
-
-.who-box{display:flex;flex-direction:column;gap:2px;margin:2px 0 12px;padding:11px 14px;
-  background:linear-gradient(135deg,rgba(217,164,65,0.16),rgba(217,164,65,0.05));
-  border:1px solid rgba(217,164,65,0.35);border-radius:10px;box-shadow:0 0 22px rgba(217,164,65,0.08);}
-.who-eyebrow{font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.14em;
-  text-transform:uppercase;color:var(--gold);opacity:.85;}
-.who-name{font-family:'Spectral',serif;font-size:17px;font-weight:600;color:#f6ead0;line-height:1.25;}
-
-.story-box{font-family:'Spectral',serif;font-size:15px;line-height:1.62;color:#e6e2d6;
-  margin:2px 0 14px;padding-left:2px;}
-.story-box::first-letter{font-size:150%;color:var(--gold);font-weight:600;}
-
-.bridge-row{padding:10px 12px;margin:6px 0;border-radius:9px;cursor:pointer;
-  background:rgba(255,255,255,0.035);border:1px solid rgba(255,255,255,0.08);transition:all .15s;}
-.bridge-row:hover{background:rgba(217,164,65,0.12);border-color:rgba(217,164,65,0.4);transform:translateX(3px);}
-.bridge-row-t{font-family:'Spectral',serif;font-size:14.5px;color:#eee7d6;line-height:1.3;}
-.bridge-row-t .arrow{color:var(--gold);}
-.bridge-row-w{font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:#9aa0ad;margin-top:3px;}
-.bridge-row-w i{color:#c7b483;font-style:normal;}
