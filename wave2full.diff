+  color:var(--ink) !important;}
+.chips .chip:hover,.chips .chip:active{background:rgba(201,162,74,.20) !important;
+  border-color:rgba(201,162,74,.55) !important;}
+.chip.stub{opacity:.6 !important;border-style:dashed !important;}
+.via-box{background:#f0e2b6 !important;border-left:3px solid var(--gilt) !important;color:#3a2f14 !important;}
+.via-box b{color:#7a5a10 !important;}
