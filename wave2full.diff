+.who-eyebrow{color:#8a6a1e !important;}
+.who-name{color:var(--ink) !important;}
+.story-box{color:#2f2718 !important;}
+.story-box::first-letter{color:var(--gilt-deep) !important;}   /* illuminated initial */
+.edge-title .arrow{color:var(--gilt-deep) !important;}
+.bridge-row{background:rgba(40,30,10,.035) !important;border:1px solid rgba(40,30,10,.10) !important;}
+.bridge-row:hover{background:rgba(201,162,74,.14) !important;border-color:rgba(201,162,74,.4) !important;}
+.bridge-row-t{color:var(--ink) !important;}
+.bridge-row-t .arrow{color:var(--gilt-deep) !important;}
+.bridge-row-w{color:#6a5c44 !important;}
+.bridge-row-w i{color:#8a6a1e !important;}
+.schuller{background:#e7ecf5 !important;color:#33414f !important;border-left:3px solid #6a86a8 !important;}
+.atom-btn{background:linear-gradient(180deg,#dfeecb,#cfe3b8) !important;color:#26361a !important;
+  border:1px solid #a9c98f !important;text-shadow:none !important;box-shadow:none !important;}
+
+/* map text: warm the topic label (its fill is set in CSS, not per-element) */
+.topic-label{fill:#b8ac90 !important;}
+
+/* ---- collapsible header ---- */
+#hdrToggle{margin-left:auto;flex:0 0 auto;width:30px;height:30px;border-radius:8px;
+  border:1px solid var(--line);background:rgba(201,162,74,.08);color:var(--gilt);
+  font-size:13px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;
+  transition:transform .28s cubic-bezier(.2,.8,.3,1),background .2s;}
+#hdrToggle:hover{background:rgba(201,162,74,.18);}
+.titlerow{align-items:center;}
+.subtitle,.legend{transition:max-height .3s ease,opacity .25s ease,margin .3s ease;
+  max-height:70px;overflow:hidden;}
+body.hdr-min .subtitle,body.hdr-min .legend{max-height:0;opacity:0;margin-top:0;pointer-events:none;}
+body.hdr-min header{padding-bottom:9px;}
+body.hdr-min h1{font-size:17px;}
+body.hdr-min #hdrToggle{transform:rotate(180deg);}
+
+/* ---- honour reduced-motion: kill even the one-time entrance ---- */
+@media (prefers-reduced-motion: reduce){
+  *,*::before,*::after{animation:none !important;}
+  .field-g.enter{opacity:1 !important;transform:none !important;}
+  #panel{transition:none !important;}
+}
