+
+/* ---- palette: manuscript pigments on aged vellum ---- */
+:root{
+  --bg:#17120b;              /* warm bister-black */
+  --bg2:#100b05;
+  --paper:#ece1c8;          /* aged parchment */
+  --paper-2:#e3d6b8;
+  --paper-edge:#cdbc92;
+  --ink:#241d12;            /* iron-gall ink */
+  --ink-soft:#6a5c44;
+  --text:#ece2cf;           /* warm off-white on the ground */
+  --text-dim:#9d917a;       /* warm taupe */
+  --gold:#c9a24a;           /* keep the historic var name = gilt */
+  --gilt:#c9a24a;
+  --gilt-bright:#e6c877;
+  --gilt-deep:#7c5c22;
+  --line:rgba(226,206,150,0.10);
+}
+
+/* ---- the ground: aged vellum in low candlelight ---- */
+body{background:radial-gradient(1200px 820px at 50% 6%,
+      #241a0f 0%, #17120b 50%, #0d0904 100%) !important;}
+
+/* faint, static paper grain over the map (fixed to the viewport, not the
+   content — so it reads as the surface you're looking through, not texture
+   painted onto the map) */
